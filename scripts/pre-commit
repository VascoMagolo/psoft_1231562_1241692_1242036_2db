#!/usr/bin/env bash
# Pre-commit hook: validates docs/ folder structure.
# Calls scripts/check-docs.py — requires Python 3.
# Install: run scripts/install-hooks.sh (Unix) or scripts/install-hooks.ps1 (Windows)

REPO_ROOT="$(git rev-parse --show-toplevel)"

if command -v python3 &>/dev/null; then
    PYTHON=python3
elif command -v python &>/dev/null; then
    PYTHON=python
else
    echo "WARNING: Python not found — skipping docs structure check."
    exit 0
fi

if ! "$PYTHON" "$REPO_ROOT/scripts/check-docs.py"; then
    echo "Commit blocked. Fix the docs structure issues listed above, then try again."
    echo "Tip: run 'python scripts/check-docs.py' at any time to check manually."
    exit 1
fi
