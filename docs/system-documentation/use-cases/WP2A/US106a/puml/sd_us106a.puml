@startuml
autonumber
actor "Backoffice Operator / ATCC" as Actor
participant "AirportController" as Ctrl
participant "AddAirportCertificationUseCase" as UC
participant "AirportRepository" as AirportRepo
participant "AircraftModelRepository" as ModelRepo
participant "AircraftCertificationRepository" as CertRepo
database "Database" as DB

Actor -> Ctrl : POST /api/airports/{iataCode}/certifications\n{ aircraftModelId: Long }
activate Ctrl

note right of Ctrl
  @Valid on AddCertificationRequest:
  - aircraftModelId: not null
end note

Ctrl -> UC : execute(iataCode: String,\n  request: AddCertificationRequest)
activate UC

UC -> AirportRepo : findByIataCodeCode(iataCode)
activate AirportRepo
AirportRepo -> DB : SELECT FROM airport WHERE code = ?
activate DB
DB --> AirportRepo : airport record
deactivate DB
AirportRepo --> UC : Airport
deactivate AirportRepo

UC -> ModelRepo : findById(request.aircraftModelId())
activate ModelRepo
ModelRepo -> DB : SELECT FROM aircraft_model WHERE id = ?
activate DB
DB --> ModelRepo : model record
deactivate DB
ModelRepo --> UC : AircraftModel
deactivate ModelRepo

UC -> CertRepo : existsByAirportAndAircraftModelId(airport, modelId)
activate CertRepo
CertRepo -> DB : SELECT COUNT(*) FROM airport_certification WHERE ...
activate DB
DB --> CertRepo : 0
deactivate DB
CertRepo --> UC : false
deactivate CertRepo

UC -> CertRepo : save(new AircraftCertification(airport, model))
activate CertRepo
CertRepo -> DB : INSERT INTO airport_certification
activate DB
DB --> CertRepo : saved record (with ID)
deactivate DB
CertRepo --> UC : AircraftCertification
deactivate CertRepo

UC --> Ctrl : AircraftCertificationResponse\n{ id, airportIataCode, aircraftModelId,\n  aircraftModelName }
deactivate UC

Ctrl --> Actor : 201 Created\nEntityModel<AircraftCertificationResponse> with _links
deactivate Ctrl
@enduml
