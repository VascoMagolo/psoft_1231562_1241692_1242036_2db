@startuml
autonumber
actor "Backoffice Operator / ATCC" as Actor
participant "AirportController" as Ctrl
participant "ViewAirportDetailsUseCase" as UC
participant "AirportRepository" as Repo
database "Database" as DB

Actor -> Ctrl : GET /api/airports/{iataCode}
activate Ctrl

Ctrl -> UC : execute(iataCode: String)
activate UC

UC -> Repo : findByIataCodeCode(iataCode)
activate Repo
Repo -> DB : SELECT FROM airport WHERE code = ?
activate DB
DB --> Repo : airport record
deactivate DB
Repo --> UC : Optional<Airport>
deactivate Repo

alt Airport found
  UC --> Ctrl : AirportResponse.from(airport)\n{ id, iataCode, name, city, country,\n  region, timezone, status, coordinates,\n  runways, contacts, services,\n  terminals, gates }
  deactivate UC
  Ctrl --> Actor : 200 OK\nEntityModel<AirportResponse> with _links:\n  self, update-status, update-details,\n  routes, certifications
else Airport not found
  UC --> Ctrl : throws AirportNotFoundException
  Ctrl --> Actor : 404 Not Found\n{ message: "Airport with IATA code '...' not found." }
end

deactivate Ctrl
@enduml
