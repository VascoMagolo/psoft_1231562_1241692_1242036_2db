@startuml
autonumber
actor "Maintenance Technician" as MT
participant "MaintenanceController" as Ctrl
participant "ViewAllMaintenanceRecordsUseCase" as UC
participant "AircraftRepository" as AircraftRepo
participant "MaintenanceRecordRepository" as Repo
database "Database" as DB

MT -> Ctrl : GET /api/maintenance/records/aircraft/{registrationNumber}\n?page=0&size=20
activate Ctrl

Ctrl -> UC : execute(registrationNumber: RegistrationNumber,\n  pageNumber: int, pageSize: int)
activate UC

UC -> AircraftRepo : findByRegistrationNumber(registrationNumber)
activate AircraftRepo
AircraftRepo -> DB : SELECT FROM aircraft WHERE registration_number = ?
activate DB
DB --> AircraftRepo : aircraft record
deactivate DB
AircraftRepo --> UC : Optional<Aircraft>
deactivate AircraftRepo

alt aircraft not found
  UC --> Ctrl : throws AircraftNotFoundException
  Ctrl --> MT : 404 Not Found\n{ message: "Aircraft '...' not found." }
else aircraft found
  UC -> Repo : findByAircraftRegistration(registrationNumber, pageNumber, pageSize)
  activate Repo
  Repo -> DB : SELECT FROM maintenance_record\nWHERE registration_number = ?\n(LIMIT ? OFFSET ?)
  activate DB
  DB --> Repo : page of records + total count
  deactivate DB
  Repo --> UC : PaginatedResult<MaintenanceRecord>
  deactivate Repo

  UC --> Ctrl : PaginatedResult<ViewAllMaintenanceRecordsResponse>
  deactivate UC

  note right of Ctrl
    Controller wraps PaginatedResult into PageImpl,
    then PagedResourcesAssembler converts it to
    PagedModel<EntityModel<ViewAllMaintenanceRecordsResponse>>
    adding _links and page metadata
  end note

  Ctrl --> MT : 200 OK (HAL+JSON)\n{\n  "_embedded": { "viewAllMaintenanceRecordsResponseList": [...] },\n  "_links": { "self", "next", "prev" },\n  "page": { number, size,\n    totalElements, totalPages }\n}
end

deactivate Ctrl
@enduml
