@startuml
autonumber
actor "ATCC" as ATCC
participant "AirportController" as Ctrl
participant "ViewAirportRoutesUseCase" as UC
participant "AirportRepository" as AirportRepo
participant "RouteRepository" as RouteRepo
database "Database" as DB

ATCC -> Ctrl : GET /api/airports/{iataCode}/routes
activate Ctrl

Ctrl -> UC : execute(iataCode: String)
activate UC

UC -> AirportRepo : existsByIataCodeCode(iataCode)
activate AirportRepo
AirportRepo -> DB : SELECT EXISTS FROM airport WHERE code = ?
activate DB
DB --> AirportRepo : true / false
deactivate DB
AirportRepo --> UC : boolean
deactivate AirportRepo

alt Airport exists
  UC -> RouteRepo : findByOriginOrDestination(iataCode)
  activate RouteRepo
  RouteRepo -> DB : SELECT FROM route\nWHERE origin_iata_code = ?\nOR destination_iata_code = ?
  activate DB
  DB --> RouteRepo : route records
  deactivate DB
  RouteRepo --> UC : List<RouteResponse>
  deactivate RouteRepo

  UC --> Ctrl : List<RouteResponse>\n[{ id, originIataCode,\n  destinationIataCode,\n  estimatedFlightTime,\n  minimumRange, minimumCapacity,\n  active }]
  deactivate UC

  Ctrl --> ATCC : 200 OK\nCollectionModel<EntityModel<RouteResponse>>\nwith _links (self, airport)
else Airport not found
  UC --> Ctrl : throws AirportNotFoundException
  Ctrl --> ATCC : 404 Not Found\n{ message: "Airport with IATA code '...' not found." }
end

deactivate Ctrl
@enduml
