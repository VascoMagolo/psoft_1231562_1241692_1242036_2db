@startuml
autonumber
actor "ATCC / Backoffice Operator" as Actor
participant "RouteController" as Ctrl
participant "UpdateRouteUseCase" as UpdateUC
participant "DesactivateRouteUseCase" as DeactivateUC
participant "RouteRepository" as Repo
participant "RouteHistoryRepository" as HistoryRepo
database "Database" as DB

== Update route details ==
Actor -> Ctrl : PUT /api/routes/{id}\nIf-Match: {version}\n{ estimatedFlightTime?, minimumRange?,\n  minimumCapacity?, active? }
activate Ctrl

Ctrl -> UpdateUC : execute(id: Long, request: UpdateRouteRequest, clientVersion: Long)
activate UpdateUC

UpdateUC -> Repo : findById(id)
activate Repo
Repo -> DB : SELECT FROM route WHERE id = ?
activate DB
DB --> Repo : route record
deactivate DB
Repo --> UpdateUC : Optional<Route>
deactivate Repo

alt route not found
  UpdateUC --> Ctrl : throws RouteNotFoundException
  Ctrl --> Actor : 404 Not Found\n{ message: "Route with id '...' not found." }
else route found
  alt version mismatch
    UpdateUC --> Ctrl : throws ObjectOptimisticLockingFailureException
    Ctrl --> Actor : 409 Conflict\n{ message: "The resource has been modified by another user." }
  else version matches
    UpdateUC -> Repo : save(route.updateRoute(\n  flightTime, range, capacity))
    activate Repo
    Repo -> DB : UPDATE route SET ... WHERE id = ?
    activate DB
    DB --> Repo : updated record
    deactivate DB
    Repo --> UpdateUC : Route
    deactivate Repo

    UpdateUC -> HistoryRepo : save(new RouteHistory(route, changeDescription, changedBy))
    activate HistoryRepo
    HistoryRepo -> DB : INSERT INTO route_history
    activate DB
    DB --> HistoryRepo : saved record
    deactivate DB
    HistoryRepo --> UpdateUC : RouteHistory
    deactivate HistoryRepo

    UpdateUC --> Ctrl : RouteResponse\n{ id, originIataCode, destinationIataCode,\n  estimatedFlightTime, minimumRange,\n  minimumCapacity, active }
    deactivate UpdateUC
    Ctrl --> Actor : 200 OK\nEntityModel<RouteResponse> with _links
  end
end

deactivate Ctrl

== Deactivate route ==
Actor -> Ctrl : PATCH /api/routes/{id}/deactivate\nIf-Match: {version}
activate Ctrl

Ctrl -> DeactivateUC : execute(id: Long, clientVersion: Long)
activate DeactivateUC

DeactivateUC -> Repo : findById(id)
activate Repo
Repo -> DB : SELECT FROM route WHERE id = ?
activate DB
DB --> Repo : route record
deactivate DB
Repo --> DeactivateUC : Optional<Route>
deactivate Repo

alt route not found
  DeactivateUC --> Ctrl : throws RouteNotFoundException
  Ctrl --> Actor : 404 Not Found\n{ message: "Route with id '...' not found." }
else route found
  alt version mismatch
    DeactivateUC --> Ctrl : throws ObjectOptimisticLockingFailureException
    Ctrl --> Actor : 409 Conflict\n{ message: "The resource has been modified by another user." }
  else version matches
    DeactivateUC -> DeactivateUC : route.deactivate()
    DeactivateUC -> Repo : save(route)
    activate Repo
    Repo -> DB : UPDATE route SET active = false WHERE id = ?
    activate DB
    DB --> Repo : updated record
    deactivate DB
    Repo --> DeactivateUC : Route
    deactivate Repo

    DeactivateUC -> HistoryRepo : save(new RouteHistory(route, "Route deactivated", changedBy))
    activate HistoryRepo
    HistoryRepo -> DB : INSERT INTO route_history
    activate DB
    DB --> HistoryRepo : saved record
    deactivate DB
    HistoryRepo --> DeactivateUC : RouteHistory
    deactivate HistoryRepo

    DeactivateUC --> Ctrl : RouteResponse\n{ id, ..., active: false }
    deactivate DeactivateUC
    Ctrl --> Actor : 200 OK\nEntityModel<RouteResponse> with _links
  end
end

deactivate Ctrl
@enduml
