@startuml
autonumber
actor "ATCC / Backoffice Operator" as Actor
participant "RouteController" as Ctrl
participant "UpdateRouteUseCase" as UpdateUC
participant "DesactivateRouteUseCase" as DeactivateUC
participant "RouteRepository" as Repo
participant "RouteHistoryRepository" as HistoryRepo
database "Database" as DB

== Update route details ==
Actor -> Ctrl : PUT /api/routes/{origin}/{destination}\nIf-Match: {version}\n{ estimatedFlightTime?, minimumRange?,\n  minimumCapacity?, active? }
activate Ctrl

Ctrl -> UpdateUC : execute(origin: String, destination: String,\n  request: UpdateRouteRequest, clientVersion: Long)
activate UpdateUC

UpdateUC -> Repo : findByOriginAndDestination(origin, destination)
activate Repo
Repo -> DB : SELECT FROM route WHERE origin_code = ? AND destination_code = ?
activate DB
DB --> Repo : route record
deactivate DB
Repo --> UpdateUC : Optional<Route>
deactivate Repo

alt route not found
  UpdateUC --> Ctrl : throws RouteNotFoundException
  Ctrl --> Actor : 404 Not Found\n{ message: "Route '...→...' not found." }
else route found
  alt version mismatch
    UpdateUC --> Ctrl : throws ConcurrencyException
    Ctrl --> Actor : 412 Precondition Failed\n{ message: "The resource has been modified by another user." }
  else version matches
    UpdateUC -> Repo : save(route.updateRoute(\n  flightTime, range, capacity))
    activate Repo
    Repo -> DB : UPDATE route SET ... WHERE origin_code = ? AND destination_code = ?
    activate DB
    DB --> Repo : updated record
    deactivate DB
    Repo --> UpdateUC : Route
    deactivate Repo

    UpdateUC -> HistoryRepo : save(new RouteHistory(origin, destination,\n  changeDescription, changedBy))
    activate HistoryRepo
    HistoryRepo -> DB : INSERT INTO route_history
    activate DB
    DB --> HistoryRepo : saved record
    deactivate DB
    HistoryRepo --> UpdateUC : RouteHistory
    deactivate HistoryRepo

    UpdateUC --> Ctrl : RouteResponse\n{ originIataCode, destinationIataCode,\n  estimatedFlightTime, minimumRange,\n  minimumCapacity, status }
    deactivate UpdateUC
    Ctrl --> Actor : 200 OK\nEntityModel<RouteResponse> with _links
  end
end

deactivate Ctrl

== Deactivate route ==
Actor -> Ctrl : PATCH /api/routes/{origin}/{destination}/deactivate\nIf-Match: {version}
activate Ctrl

Ctrl -> DeactivateUC : execute(origin: String, destination: String, clientVersion: Long)
activate DeactivateUC

DeactivateUC -> Repo : findByOriginAndDestination(origin, destination)
activate Repo
Repo -> DB : SELECT FROM route WHERE origin_code = ? AND destination_code = ?
activate DB
DB --> Repo : route record
deactivate DB
Repo --> DeactivateUC : Optional<Route>
deactivate Repo

alt route not found
  DeactivateUC --> Ctrl : throws RouteNotFoundException
  Ctrl --> Actor : 404 Not Found\n{ message: "Route '...→...' not found." }
else route found
  alt version mismatch
    DeactivateUC --> Ctrl : throws ConcurrencyException
    Ctrl --> Actor : 412 Precondition Failed\n{ message: "The resource has been modified by another user." }
  else version matches
    DeactivateUC -> DeactivateUC : route.setStatus(RouteStatus.INACTIVE)
    DeactivateUC -> Repo : save(route)
    activate Repo
    Repo -> DB : UPDATE route SET status = 'INACTIVE' WHERE origin_code = ? AND destination_code = ?
    activate DB
    DB --> Repo : updated record
    deactivate DB
    Repo --> DeactivateUC : Route
    deactivate Repo

    DeactivateUC -> HistoryRepo : save(new RouteHistory(origin, destination,\n  "Route deactivated", changedBy))
    activate HistoryRepo
    HistoryRepo -> DB : INSERT INTO route_history
    activate DB
    DB --> HistoryRepo : saved record
    deactivate DB
    HistoryRepo --> DeactivateUC : RouteHistory
    deactivate HistoryRepo

    DeactivateUC --> Ctrl : RouteResponse\n{ ..., status: INACTIVE }
    deactivate DeactivateUC
    Ctrl --> Actor : 200 OK\nEntityModel<RouteResponse> with _links
  end
end

deactivate Ctrl
@enduml
