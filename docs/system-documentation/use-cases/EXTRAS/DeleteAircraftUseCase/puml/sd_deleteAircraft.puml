@startuml sd_deleteAircraft
autonumber
skinparam monochrome true
skinparam packageStyle rect
skinparam shadowing false

actor "Backoffice Operator" as BO
participant "AircraftController" as Ctrl
participant "DeleteAircraftUseCase" as UC
participant "AircraftRepository" as Repo
database "Database" as DB

BO -> Ctrl : DELETE /api/aircrafts/{registration}
activate Ctrl

Ctrl -> UC : execute(registration)
activate UC

UC -> Repo : findByRegistrationNumber(registration)
activate Repo
Repo -> DB : SELECT FROM aircraft WHERE registration_number = ?
activate DB
DB --> Repo : aircraft record
deactivate DB
Repo --> UC : Optional<Aircraft>
deactivate Repo

alt aircraft not found
    UC --> Ctrl : throws AircraftNotFoundException
    Ctrl --> BO : 404 Not Found
else aircraft found
    UC -> Repo : delete(aircraft)
    activate Repo
    Repo -> DB : DELETE FROM aircraft WHERE registration_number = ?
    activate DB
    DB --> Repo : success
    deactivate DB
    deactivate Repo
    UC --> Ctrl : void
    deactivate UC
    Ctrl --> BO : 204 No Content
end

deactivate Ctrl
@enduml
