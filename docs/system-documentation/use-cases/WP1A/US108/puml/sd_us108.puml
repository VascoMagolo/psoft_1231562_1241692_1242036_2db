@startuml sd_us108
autonumber
skinparam monochrome true
skinparam packageStyle rect
skinparam shadowing false

actor "Backoffice Operator" as BO
participant "AircraftModelController" as Ctrl
participant "UpdateAircraftModelUseCase" as UC
participant "AircraftModelRepository" as Repo
participant "AircraftModel" as Model
database "Database" as DB

BO -> Ctrl : PATCH /api/aircraftModels/{modelName}\n{ cruisingSpeed?, fuelCapacity?,\n  maxRange?, maximumSeatingCapacity?,\n  imagePath? }
activate Ctrl

note right of Ctrl
  UpdateAircraftModelRequest:
  - cruisingSpeed: optional
  - fuelCapacity: optional
  - maxRange: optional
  - maximumSeatingCapacity: optional
  - imagePath: optional
end note

Ctrl -> UC : execute(modelName, request: UpdateAircraftModelRequest)
activate UC

UC -> Repo : findByModelName(modelName)
activate Repo
Repo -> DB : SELECT FROM aircraft_model WHERE model_name = ?
activate DB
DB --> Repo : model record
deactivate DB
Repo --> UC : Optional<AircraftModel>
deactivate Repo

alt model not found
    UC --> Ctrl : throws AircraftModelNotFoundException
    Ctrl --> BO : 404 Not Found
else model found
    UC -> Model : update(request)
    activate Model
    deactivate Model
    UC -> Repo : save(model)
    activate Repo
    Repo -> DB : UPDATE aircraft_model ...
    activate DB
    DB --> Repo : success
    deactivate DB
    Repo --> UC : savedModel
    deactivate Repo
    UC --> Ctrl : AircraftModelResponse\n{ modelName, manufacturer, fuelCapacity,\n  maxRange, cruisingSpeed, imagePath,\n  maximumSeatingCapacity }
    deactivate UC
    Ctrl --> BO : 200 OK\nEntityModel<AircraftModelResponse> with _links
end

deactivate Ctrl
@enduml
