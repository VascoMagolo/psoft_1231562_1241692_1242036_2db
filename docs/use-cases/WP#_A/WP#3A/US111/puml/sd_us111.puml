@startuml
autonumber
actor "ATCC" as Actor
participant "RouteController" as Ctrl
participant "ViewRouteHistoryUseCase" as UC
participant "RouteRepository" as RouteRepo
participant "RouteHistoryRepository" as HistoryRepo
database "Database" as DB

Actor -> Ctrl : GET /api/routes/{id}/history
activate Ctrl

Ctrl -> UC : execute(routeId)
activate UC

UC -> RouteRepo : findById(routeId)
activate RouteRepo
RouteRepo -> DB : SELECT FROM route WHERE id = ?
activate DB
DB --> RouteRepo : route record / empty
deactivate DB
RouteRepo --> UC : Optional<Route>
deactivate RouteRepo

alt Route found
    UC -> HistoryRepo : findAllByRouteId(routeId)
    activate HistoryRepo
    HistoryRepo -> DB : SELECT FROM route_history WHERE route_id = ?
    activate DB
    DB --> HistoryRepo : history records
    deactivate DB
    HistoryRepo --> UC : List<RouteHistory>
    deactivate HistoryRepo
    UC --> Ctrl : List<RouteHistory>
    Ctrl --> Actor : 200 OK (JSON)
else Route not found
    UC --> Ctrl : throws RouteNotFoundException
    Ctrl --> Actor : 404 Not Found
end

deactivate UC
deactivate Ctrl
@enduml
