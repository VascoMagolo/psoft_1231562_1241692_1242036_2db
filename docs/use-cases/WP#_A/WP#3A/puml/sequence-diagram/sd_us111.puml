@startuml
autonumber
actor "ATCC" as Actor
participant "RouteController" as Ctrl
participant "ViewRouteHistoryUseCase" as UC
participant "RouteHistoryRepository" as Repo
database "Database" as DB

Actor -> Ctrl : GET /api/routes/{id}/history
activate Ctrl

Ctrl -> UC : execute(routeId)
activate UC

UC -> Repo : findAllByRouteId(routeId)
activate Repo
Repo -> DB : SELECT FROM route_history WHERE route_id = ?
activate DB
DB --> Repo : history records
deactivate DB
Repo --> UC : List<RouteHistory>
deactivate Repo

UC --> Ctrl : RouteHistoryList
Ctrl --> Actor : 200 OK (JSON)

deactivate UC
deactivate Ctrl
@enduml